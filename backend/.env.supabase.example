# Supabase Postgres connection for Spring Boot backend
# Get values from Supabase Dashboard -> Project Settings -> Database

# REQUIRED: use Session pooler host + port from Supabase
# Example host: aws-0-ap-northeast-2.pooler.supabase.com
SUPABASE_DB_JDBC_URL=jdbc:postgresql://<POOLER_HOST>:6543/postgres?sslmode=require
SUPABASE_DB_USER=<DB_USER>
SUPABASE_DB_PASSWORD=<DB_PASSWORD>

# Backend runtime
JWT_SECRET=<LONG_RANDOM_SECRET_AT_LEAST_32_CHARS>
ADMIN_PASSCODE_HASH=<BCRYPT_HASH>
ALLOWED_ORIGINS=https://<your-frontend-domain>

# Optional (cloud runtime usually sets this automatically)
PORT=8080
