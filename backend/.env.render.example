# Render DB + Spring Boot backend env example

# Use JDBC URL with sslmode=require (no sslrootcert / verify-full)
SPRING_DATASOURCE_URL=jdbc:postgresql://<render-host>:5432/<db-name>?sslmode=require
SPRING_DATASOURCE_USERNAME=<db-user>
SPRING_DATASOURCE_PASSWORD=<db-password>

JWT_SECRET=<LONG_RANDOM_SECRET_AT_LEAST_32_CHARS>
ADMIN_PASSCODE_HASH=<BCRYPT_HASH>
ALLOWED_ORIGINS=https://<your-frontend-domain>,https://<your-dev-frontend-domain>

# Render usually injects this automatically
PORT=8080
